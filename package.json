{
  "name": "hl-cockpit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "panda:prepare": "panda codegen",
    "postinstall": "panda codegen",
    "dev": "panda codegen && next dev",
    "build": "panda codegen && next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type:check": "tsc --noEmit",
    "test": "SUPPRESS_TEST_OUTPUT=true vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:lib": "SUPPRESS_TEST_OUTPUT=true vitest run --config vitest.config.lib.ts --reporter=dot",
    "test:ui": "SUPPRESS_TEST_OUTPUT=true vitest run --config vitest.config.ui.ts --reporter=dot",
    "validate": "pnpm type:check && pnpm test && pnpm lint && pnpm build",
    "env:pull": "vercel env pull .env.local",
    "env:help": "echo 'Run: pnpm env:pull to pull Vercel env vars into .env.local (repo must be linked: vercel link). Sensitive vars added manually if needed.'",
    "skill:analyze-traders": "tsx --tsconfig tsconfig.scripts.json scripts/analyze-traders.ts",
    "skill:analyze-market": "tsx --tsconfig tsconfig.scripts.json scripts/analyze-market.ts",
    "skill:open-position": "tsx --tsconfig tsconfig.scripts.json scripts/open-position.ts",
    "skill:assess-health": "tsx --tsconfig tsconfig.scripts.json scripts/assess-health.ts",
    "skill:advise-exit": "tsx --tsconfig tsconfig.scripts.json scripts/advise-exit.ts",
    "skill:refresh-exit": "tsx --tsconfig tsconfig.scripts.json scripts/refresh-exit.ts",
    "skill:run-session": "tsx --tsconfig tsconfig.scripts.json scripts/run-session.ts",
    "skill:report-context": "tsx --tsconfig tsconfig.scripts.json scripts/report-context.ts",
    "skill:review-previews": "tsx --tsconfig tsconfig.scripts.json scripts/review-previews.ts",
    "skill:review-ladder": "tsx --tsconfig tsconfig.scripts.json scripts/review-ladder.ts",
    "skill:ladder-expectancy": "tsx --tsconfig tsconfig.scripts.json scripts/ladder-expectancy.ts",
    "smoke": "tsx --tsconfig tsconfig.scripts.json scripts/_smoke-cockpit.ts",
    "verify:design": "tsx --tsconfig tsconfig.scripts.json scripts/_verify-design.ts",
    "smoke:data": "tsx --tsconfig tsconfig.scripts.json scripts/_smoke.ts",
    "watch": "tsx --tsconfig tsconfig.scripts.json scripts/watch.ts",
    "trader-watch": "tsx --tsconfig tsconfig.scripts.json scripts/trader-watch.ts",
    "vault-watch": "tsx --tsconfig tsconfig.scripts.json scripts/vault-watch.ts",
    "scout:lanes": "tsx --tsconfig tsconfig.scripts.json scripts/scout-lanes.ts",
    "research-trader-worker": "tsx --tsconfig tsconfig.scripts.json scripts/research-trader-worker.ts",
    "review-trader": "tsx --tsconfig tsconfig.scripts.json scripts/review-trader.ts",
    "enqueue-all-vets": "tsx --tsconfig tsconfig.scripts.json scripts/enqueue-all-vets.ts",
    "vet-status": "tsx --tsconfig tsconfig.scripts.json scripts/vet-status.ts",
    "retry-vet-errors": "tsx --tsconfig tsconfig.scripts.json scripts/retry-vet-errors.ts",
    "upsert-rated": "tsx --tsconfig tsconfig.scripts.json scripts/upsert-rated-wallets.ts",
    "gen:secret": "tsx --tsconfig tsconfig.scripts.json scripts/gen-secret.ts",
    "rubric": "tsx --tsconfig tsconfig.scripts.json scripts/rubric-scan.ts",
    "scout:watch": "tsx --tsconfig tsconfig.scripts.json scripts/scout-watch.ts",
    "scout:cycle": "tsx --tsconfig tsconfig.scripts.json scripts/scout-cycle.ts",
    "scout:trade": "tsx --tsconfig tsconfig.scripts.json scripts/scout-trade.ts",
    "scout:review": "tsx --tsconfig tsconfig.scripts.json scripts/scout-review.ts",
    "backtest": "tsx --tsconfig tsconfig.scripts.json scripts/backtest.ts",
    "backtest:study": "tsx --tsconfig tsconfig.scripts.json scripts/backtest-study.ts",
    "backtest:oos": "tsx --tsconfig tsconfig.scripts.json scripts/backtest-oos.ts",
    "backtest:calibration": "tsx --tsconfig tsconfig.scripts.json scripts/backtest-calibration.ts",
    "backtest:exit": "tsx --tsconfig tsconfig.scripts.json scripts/backtest-exit.ts",
    "backtest:funding": "tsx --tsconfig tsconfig.scripts.json scripts/backtest-funding.ts",
    "backtest:htf": "tsx --tsconfig tsconfig.scripts.json scripts/backtest-htf.ts",
    "backtest:significance": "tsx --tsconfig tsconfig.scripts.json scripts/backtest-significance.ts"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.2",
    "@supabase/supabase-js": "^2.47.10",
    "lightweight-charts": "^5.2.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "uuid": "^13.0.2",
    "viem": "^2.52.2",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@pandacss/dev": "^1.9.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "jsdom": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
